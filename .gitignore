# 隐藏文件：所有 . 开头默认 ignore，例外仅 .gitignore / .gitattributes / .env.example
.*
!.gitignore
!.gitattributes
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
*.egg

# Virtual environment
venv/
env/

# OS
.DS_Store
Thumbs.db

# Docker
pgdata/

# Logs
*.log

# Coverage
htmlcov/
.coverage
.coverage.*
